# RainbowKit wallet connect — get a free project ID at https://cloud.reown.com.
# Only needed for the WalletConnect (mobile/QR) connector; MetaMask, Coinbase
# Wallet, and other browser-extension wallets work via the injected connector
# even without a real value here.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com

# Deployed contracts (from contracts/deployments/monadTestnet.json after Phase 2 deploy)
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_TOKEN_DECIMALS=6

# Optional - a Goldsky (or any Graph-node-compatible) subgraph indexing AgentVault's events.
# Used only to speed up the historical backfill; if unset, vaultEvents.tsx falls back to a
# direct (slower, RPC-range-limited) eth_getLogs scan. See lib/goldsky.ts for the expected
# schema shape (one entity per event, Graph Node's standard first/orderBy/where args).
NEXT_PUBLIC_GOLDSKY_SUBGRAPH_URL=
