# Chain connection
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143
EXPLORER_URL=https://testnet.monadexplorer.com

# Deployed contracts (from contracts/deployments/monadTestnet.json after Phase 2 deploy)
VAULT_ADDRESS=
TOKEN_ADDRESS=

# The agent's own throwaway keypair. This address must be registered by the
# vault owner (see contracts/scripts/registerAgent.ts). Fund it with a small
# amount of MON for gas - it holds no token funds, ever.
AGENT_PRIVATE_KEY=

# Only needed for the demo/CLI harness (src/demo.ts) so it can also play the
# owner's part (approve + revoke) end-to-end without the dashboard. In a real
# run these actions come from the dashboard, not this key.
OWNER_PRIVATE_KEY=

# Claude API key for the agent's spend-decision LLM call (src/llm.ts).
# If unset, the agent falls back to a deterministic heuristic decision so
# demos still run offline.
ANTHROPIC_API_KEY=

# For `npm run spend -- "<goal>"` - JSON map of label -> whitelisted recipient address
ALLOWED_RECIPIENTS={"cloud-provider":"0x0000000000000000000000000000000000000000"}

# For src/demo.ts
RECIPIENT_ADDRESS=

POLL_INTERVAL_MS=3000
APPROVAL_POLL_TIMEOUT_MS=300000

# --- Door 2 / ERC-4337 (bonus, Phase 6) ---
# Verify these against Pimlico's current Monad-testnet docs before relying on
# Door 2 for a live demo; Door 1 above needs none of this.
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=
