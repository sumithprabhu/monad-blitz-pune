# Monad testnet RPC (verify this is still current before deploying)
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Private key used to deploy contracts. Needs MON for gas (use the testnet faucet).
DEPLOYER_PRIVATE_KEY=

# Optional: vault owner address, if different from the deployer.
# If unset, the deployer becomes the vault owner.
OWNER_ADDRESS=

# Optional: ERC-4337 EntryPoint address for Door 2. Defaults to the canonical
# v0.7 address below - verify it is actually deployed on Monad testnet first
# (scripts/deploy.ts will warn if there's no contract code there).
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# Optional: how much mUSDC to mint/seed into the vault on deploy.
SEED_AMOUNT_USDC=50000

# For scripts/registerAgent.ts
# VAULT_ADDRESS=
# AGENT_ADDRESS=
# RECIPIENT_ADDRESS=
# PER_TX_CAP=100
# DAILY_CAP=500
# APPROVAL_THRESHOLD=50
# WHITELIST_ONLY=true

# Optional: gas reporting during tests
REPORT_GAS=false
